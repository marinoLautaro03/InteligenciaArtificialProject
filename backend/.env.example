PORT=3001
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/ia_project

# Clerk authentication
CLERK_SECRET_KEY=sk_test_...

# AI — text generation (OpenAI-compatible, e.g. Azure Foundry)
AI_TEXT_MODEL=gpt-4o-mini
AI_TEXT_BASE_URL=https://your-resource.openai.azure.com/openai/v1
AI_TEXT_API_KEY=your-key

# AI — image generation (Azure Foundry + Black Forest Labs)
# base URL is the path up to (but not including) the model name
AI_IMAGE_MODEL=FLUX.2-pro
AI_IMAGE_BASE_URL=https://your-resource.services.ai.azure.com/providers/blackforestlabs/v1
AI_IMAGE_API_KEY=your-key
